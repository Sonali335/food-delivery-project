MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=Cluster0
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Google Sign-In (POST /auth/google); Web client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# --- Email (OTP signup / password reset) — without this, codes only print in the server terminal ---
# Option A — Gmail (SMTP_PASS must be an App Password, not your normal Gmail password)
#
# Why you might NOT see “App passwords” in Google Account:
#   - 2-Step Verification is OFF → turn it on first (Security → How you sign in to Google).
#   - 2-Step Verification uses ONLY security keys / passkeys and no other second step → add
#     “Google prompt” or “Authenticator app” as a backup method, then App passwords can appear.
#   - Work / school (@company.com) account → your admin may block app passwords; use Option B.
#   - Advanced Protection is ON → app passwords are disabled; use Option B.
#
# Steps (personal @gmail.com):
#   1) Open https://myaccount.google.com/security
#   2) Under “How you sign in to Google”, turn on “2-Step Verification” and finish setup.
#   3) Open https://myaccount.google.com/apppasswords (or Security → search “app passwords”).
#   4) Create an app password, copy the 16 characters into SMTP_PASS below.
#   5) SMTP_USER = that same account’s full email (e.g. you@gmail.com).
SMTP_SERVICE=gmail
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Optional “From” header (defaults to SMTP_USER)
# SMTP_FROM=You <you@gmail.com>
# Name shown in OTP email headers/body (default: Food delivery)
# MAIL_APP_NAME=My Kitchen

# --- Cloudinary (menu images, POST /menu/upload-image) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Option B — any SMTP host (omit SMTP_SERVICE or leave it blank)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
