# Web client ID from Google Cloud Console (same value as backend GOOGLE_CLIENT_ID).
# You can set VITE_GOOGLE_CLIENT_ID here OR only GOOGLE_CLIENT_ID in backend/.env —
# vite.config.js merges backend + repo-root + frontend env (see that file).
VITE_GOOGLE_CLIENT_ID=

# Optional: full backend URL for production builds (no dev proxy). Example: https://api.example.com
# VITE_API_BASE_URL=

# Optional: where Vite proxies /auth and /profile in dev (default http://localhost:5000)
# VITE_API_PROXY_TARGET=
